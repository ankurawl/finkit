# FinKit API Keys
# Copy this file to your finance data directory as .env
# e.g., cp .env.example ~/finance/.env
#
# Most price sources work without API keys but may have rate limits.
# Add keys for higher limits or premium features.

# Alpha Vantage — alternative stock price source (if yfinance is unavailable)
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# CoinGecko — crypto prices (free tier needs no key, pro tier is faster)
# Get a key at: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# ExchangeRate-API — currency exchange rates (free tier requires a key)
# Get a free key at: https://www.exchangerate-api.com/
EXCHANGERATE_API_KEY=
